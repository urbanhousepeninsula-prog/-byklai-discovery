        "emailType": "html",
        "message": "=<div style='font-family:sans-serif;max-width:620px;color:#0a0a0a'><h2 style='font-size:18px;border-bottom:2px solid #0a0a0a;padding-bottom:10px;margin-bottom:20px'>Nuevo Discovery recibido</h2><table style='width:100%;border-collapse:collapse;font-size:13px'><tr style='background:#f2f1ed'><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Nombre</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ $('Webhook').item.json.body.nombre }}</td></tr><tr><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Empresa</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ $('Webhook').item.json.body.empresa }}</td></tr><tr style='background:#f2f1ed'><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Email</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ $('Webhook').item.json.body.email }}</td></tr><tr><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Teléfono</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ $('Webhook').item.json.body.telefono }}</td></tr><tr style='background:#f2f1ed'><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Origen</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ $('Webhook').item.json.body.origenLead }}</td></tr><tr><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Tipos de Proyecto</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ Array.isArray($('Webhook').item.json.body.tiposProyecto) ? $('Webhook').item.json.body.tiposProyecto.join(', ') : '' }}</td></tr><tr style='background:#f2f1ed'><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Objetivo</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ $('Webhook').item.json.body.objetivoPrincipal }}</td></tr><tr><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Presupuesto</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ $('Webhook').item.json.body.presupuesto }}</td></tr><tr style='background:#f2f1ed'><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Timeline</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ $('Webhook').item.json.body.timeline }}</td></tr><tr><td style='padding:8px 12px;border:1px solid #ddd;font-weight:600'>Diagnóstico Premium</td><td style='padding:8px 12px;border:1px solid #ddd'>{{ $('Webhook').item.json.body.diagnosticoPremium ? 'Sí' : 'No' }}</td></tr></table></div>"
      },
