{
  "name": "byklai — Discovery Estratégico",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "byklai-discovery",
        "responseMode": "onReceived",
        "options": {
          "allowedOrigins": "*"
        }
      },
      "id": "node-001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "byklai-discovery"
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "105aRA9ISBRLZXDvAo6hb_Ig5hzMtqxwZdOnLhwf1Sm8",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "gid=0",
          "mode": "id"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Timestamp": "={{ $now.toISO() }}",
            "Nombre": "={{ $json.body.nombre }}",
            "Empresa": "={{ $json.body.empresa }}",
            "Email": "={{ $json.body.email }}",
            "Teléfono": "={{ $json.body.telefono }}",
            "Sitio Web": "={{ $json.body.sitioWeb || '' }}",
            "Redes Sociales": "={{ $json.body.redesSociales || '' }}",
            "Origen": "={{ $json.body.origenLead }}",
            "Es Decisor": "={{ $json.body.esDecison }}",
            "Tipos de Proyecto": "={{ Array.isArray($json.body.tiposProyecto) ? $json.body.tiposProyecto.join(', ') : '' }}",
            "Objetivo Principal": "={{ $json.body.objetivoPrincipal }}",
            "Estado Web": "={{ $json.body.estadoWeb }}",
            "Usa CRM": "={{ $json.body.usaCRM }}",
            "Tiene Automatizaciones": "={{ $json.body.tieneAutomatizaciones }}",
            "Herramientas": "={{ $json.body.herramientasActuales || '' }}",
            "Alcance Esperado": "={{ $json.body.alcanceEsperado }}",
            "Presupuesto": "={{ $json.body.presupuesto }}",
            "Timeline": "={{ $json.body.timeline }}",
            "Estado Proyecto": "={{ $json.body.estadoProyecto }}",
            "Expectativas": "={{ Array.isArray($json.body.expectativas) ? $json.body.expectativas.join(', ') : '' }}",
            "Diagnóstico Premium": "={{ $json.body.diagnosticoPremium ? 'Sí' : 'No' }}",
            "Info Adicional": "={{ $json.body.informacionAdicional || '' }}"
          },
          "matchingColumns": [],
          "schema": []
        },
        "options": {}
      },
      "id": "node-002",
      "name": "Google Sheets — Registrar",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [460, 300],
